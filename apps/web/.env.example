# URL the dashboard calls for API + auth. In docker-compose, point at the api service.
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Public origin of the dashboard. Used by Better Auth for redirect/callback URLs.
BETTER_AUTH_URL="http://localhost:3000"

# Optional: only set if you front the dashboard with a custom domain.
# NEXTAUTH_URL="https://jex.yourcompany.com"
